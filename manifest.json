{
  "manifest_version": 3,
  "name": "GPTPrint Pro – Print & Export ChatGPT to PDF",
  "version": "1.0.1",
  "description": "Customize and print ChatGPT conversations with themes, watermark, header, and layout control.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "GPTPrint Pro"
  },
  "permissions": ["storage", "tabs"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*", "https://chat.openai.com/*"],
      "js": [
        "content.js",
        "content-toggle.js",
        "content-premium.js",
        "content-user.js",
        "content-assistant.js",
        "content-new-features.js",
        "content-chat-toggle.js",
        "content-devrelix-button.js"
      ],
      "css": ["content-styles.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["popup.html", "popup.css", "popup.js"],
      "matches": ["https://chat.openai.com/*", "https://chatgpt.com/*"]
    }
  ]
}
